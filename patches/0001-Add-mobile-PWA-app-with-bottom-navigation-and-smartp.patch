+function isMobileLayout(){return window.matchMedia('(max-width:700px)').matches;}
+
+function initMobileLayout(){
+  const mob=isMobileLayout();
+  document.documentElement.classList.toggle('is-mobile',mob);
+  const sw=document.getElementById('search-wrap');
+  if(sw){
+    if(mob&&!sw.classList.contains('mobile-open')) sw.classList.add('mobile-collapsed');
+    else{sw.classList.remove('mobile-collapsed');sw.classList.remove('mobile-open');}
+  }
+  if(mob&&!localStorage.getItem('tp_mobile_inited')){
+    if(calV==='month') setCalView('day');
+    localStorage.setItem('tp_mobile_inited','1');
+  }
+}
+
+function initMobileDrawer(){
+  const src=document.getElementById('sidebar');
+  const tgt=document.getElementById('mobile-drawer-content');
+  if(src&&tgt&&!tgt.dataset.ready){
+    tgt.innerHTML=src.innerHTML;
+    tgt.dataset.ready='1';
+  }
+}
+
+function openMobileDrawer(){
+  initMobileDrawer();
